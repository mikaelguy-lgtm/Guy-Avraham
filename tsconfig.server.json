{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "dist-server",
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["server.ts", "src/config/env.ts", "src/db/**/*.ts", "src/domain/**/*.ts", "src/middleware/**/*.ts", "src/server/**/*.ts", "src/services/**/*.ts", "src/utils/audit.ts"],
  "exclude": ["tests", "dist", "dist-server"]
}

